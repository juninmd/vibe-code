# =============================================================================
# vibe-code + LiteLLM environment variables
# Copy to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# ─── LiteLLM Proxy ───────────────────────────────────────────────────────────
# URL where the LiteLLM proxy is running.
# Default for docker-compose: http://litellm:4000
# For local dev (LiteLLM running separately): http://localhost:4000
LITELLM_BASE_URL=http://localhost:4000

# Master key used by vibe-code server to create/delete virtual keys.
# Set this to a strong random secret (e.g. `openssl rand -hex 32`).
# This key is NEVER exposed via API or UI.
LITELLM_MASTER_KEY=sk-your-master-key-here

# ─── LiteLLM Admin UI ────────────────────────────────────────────────────────
# Credentials to log in to http://localhost:4000/ui
UI_USERNAME=admin
UI_PASSWORD=changeme

# ─── PostgreSQL (for LiteLLM spend tracking & virtual keys) ─────────────────
POSTGRES_PASSWORD=litellmpassword
DATABASE_URL=postgresql://litellm:litellmpassword@localhost:5432/litellm

# ─── Provider API Keys (go to LiteLLM ONLY, never to vibe-code engines) ─────
# These are read exclusively by LiteLLM. The vibe-code server never reads them.
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-openai-key-here
GEMINI_API_KEY=your-gemini-key-here

# ─── Git Providers ───────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_your-github-token
GITLAB_TOKEN=glpat-your-gitlab-token

# ─── GitHub Copilot Engine ───────────────────────────────────────────────────
# OAuth token for Copilot CLI authentication (one of the three below is used).
# Alternatively, install @github/copilot-sdk globally to bundle the CLI.
COPILOT_GITHUB_TOKEN=ghp_your-copilot-token-here
# GH_TOKEN=  # alternative — any GitHub token with Copilot access
# GITHUB_TOKEN=  # alternative — used as last-resort auth by the CLI

# Optional: override the path to the Copilot CLI binary.
# Default: $( npm root -g )/@github/copilot-sdk/node_modules/.bin/copilot
# COPILOT_CLI_PATH=/usr/local/bin/copilot

# ─── vibe-code server ────────────────────────────────────────────────────────
PORT=3000
VIBE_CODE_DATA_DIR=~/.vibe-code
VIBE_CODE_MAX_AGENTS=4
