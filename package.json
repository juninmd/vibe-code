{
  "name": "vibe-code",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bash ./scripts/dev-safe.sh",
    "dev:raw": "bun run --filter '*' dev",
    "dev:server": "bun run --filter @vibe-code/server dev",
    "dev:web": "bun run --filter @vibe-code/web dev",
    "build": "bun run --filter '*' build",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun run --filter '*' test",
    "lint": "node_modules/.bin/biome check packages/",
    "lint:fix": "node_modules/.bin/biome check --write packages/",
    "format": "bunx biome format --write packages/",
    "prepare": "husky"
  },
  "lint-staged": {
    "packages/**/*.{ts,tsx}": [
      "node_modules/.bin/biome check --write --no-errors-on-unmatched"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  },
  "dependencies": {
    "hono": "^4.12.14",
    "typescript": "^6.0.3"
  }
}