    "test": "bun test src --timeout 15000"
  },
  "dependencies": {
    "@vibe-code/shared": "workspace:*",
    "croner": "^10.0.1",
    "dotenv": "^17.4.2",
    "hono": "^4.12.15",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "typescript": "^5.8.3"
  }
}
